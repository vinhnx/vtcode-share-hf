{
  "name": "vtcode-share-hf",
  "version": "1.0.0",
  "description": "Collect, review, reject, and upload redacted vtcode session traces to Hugging Face",
  "type": "module",
  "bin": {
    "vtcode-share-hf": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit && eslint src --ext .ts",
    "lint": "eslint src --ext .ts",
    "test": "bun test",
    "viewer": "node dist/atif-viewer.js"
  },
  "keywords": ["vtcode", "huggingface", "agent-traces", "pii-redaction"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
